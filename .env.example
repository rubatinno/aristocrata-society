# Crie um projeto em https://supabase.com e preencha as chaves abaixo.
# Encontradas em: Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave "service_role" — NUNCA exponha no client. Usada apenas em Server Actions
# para criar agendamentos com segurança (bypass de RLS controlado pelo servidor).
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app, usada para montar o link de agendamento (ex: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth do Google (Cloud Console > APIs & Services > Credentials), usado pra
# cada mentor conectar a própria Google Calendar. Redirect URI autorizada:
# {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
